{
  "name": "vite-react-ts-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --open",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "format:lint": "pnpm run format && pnpm run lint",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm run format:lint && npx tsc && vite build",
    "preview": "vite preview --host --open",
    "build:preview": "pnpm run build && pnpm run preview"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-dom": "^2.13.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-react-x": "^2.13.0",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.30.0"
}
